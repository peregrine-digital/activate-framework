{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "preLaunchTask": "prepare-assets"
    },
    {
      "name": "Integration Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/..",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/src/test/integration"
      ],
      "preLaunchTask": "prepare-assets"
    }
  ]
}
