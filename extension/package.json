{
  "name": "peregrine-activate",
  "displayName": "Peregrine Activate",
  "description": "Cross-functional agentic framework for government delivery teams — install Copilot instructions, prompts, skills, and agents into your workspace.",
  "version": "0.5.0",
  "publisher": "peregrine",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/peregrine-digital/activate-framework"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "agents",
    "instructions",
    "skills",
    "government"
  ],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "activate-framework.install",
        "title": "Peregrine Activate: Install into Workspace"
      },
      {
        "command": "activate-framework.update",
        "title": "Peregrine Activate: Check for Updates"
      },
      {
        "command": "activate-framework.showInstalled",
        "title": "Peregrine Activate: Show Installed Files"
      }
    ],
    "configuration": {
      "title": "Peregrine Activate",
      "properties": {
        "activate-framework.defaultTier": {
          "type": "string",
          "default": "standard",
          "enum": [
            "minimal",
            "standard",
            "advanced"
          ],
          "enumDescriptions": [
            "Core workflow guidance (AGENTS.md, instructions, prompts)",
            "Core + ad-hoc instructions, skills, and agents",
            "Standard + advanced tooling"
          ],
          "description": "Default installation tier when installing Peregrine Activate."
        },
        "activate-framework.targetSubdir": {
          "type": "string",
          "default": ".github",
          "description": "Subdirectory within the workspace where files are installed (e.g. .github or .copilot)."
        }
      }
    }
  },
  "scripts": {
    "prepare-assets": "node scripts/prepare-assets.mjs",
    "package": "npm run prepare-assets && vsce package --no-dependencies --allow-missing-repository --skip-license",
    "test": "node --test src/__tests__/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0"
  }
}
