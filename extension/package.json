{
  "name": "peregrine-activate",
  "displayName": "Peregrine Activate",
  "description": "Cross-functional agentic framework for government delivery teams — install Copilot instructions, prompts, skills, and agents into your workspace.",
  "version": "0.5.0",
  "publisher": "peregrine",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/peregrine-digital/activate-framework"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "agents",
    "instructions",
    "skills",
    "government"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "peregrine-activate",
          "title": "Peregrine Activate",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "peregrine-activate": [
        {
          "type": "webview",
          "id": "activate-framework.controlPanel",
          "name": "Activate"
        }
      ]
    },
    "commands": [
      {
        "command": "activate-framework.changeTier",
        "title": "Peregrine Activate: Change Tier",
        "icon": "$(settings-gear)"
      },
      {
        "command": "activate-framework.showStatus",
        "title": "Peregrine Activate: Show Status"
      },
      {
        "command": "activate-framework.remove",
        "title": "Peregrine Activate: Remove Files"
      },
      {
        "command": "activate-framework.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "activate-framework.addToWorkspace",
        "title": "Install Files",
        "icon": "$(add)"
      },
      {
        "command": "activate-framework.removeFromWorkspace",
        "title": "Remove Files",
        "icon": "$(remove)"
      },
      {
        "command": "activate-framework.updateAll",
        "title": "Update All Installed Files",
        "icon": "$(sync)"
      },
      {
        "command": "activate-framework.installFile",
        "title": "Install",
        "icon": "$(cloud-download)"
      },
      {
        "command": "activate-framework.uninstallFile",
        "title": "Uninstall",
        "icon": "$(trash)"
      },
      {
        "command": "activate-framework.openFile",
        "title": "Open File"
      },
      {
        "command": "activate-framework.diffFile",
        "title": "Peregrine Activate: Diff File (Installed vs Bundled)"
      },
      {
        "command": "activate-framework.skipFileUpdate",
        "title": "Peregrine Activate: Skip File Update"
      },
      {
        "command": "activate-framework.changeManifest",
        "title": "Peregrine Activate: Change Manifest"
      },
      {
        "command": "activate-framework.telemetryRunNow",
        "title": "Peregrine Activate: Run Copilot Telemetry Log Now"
      }
    ],
    "configuration": {
      "title": "Peregrine Activate",
      "properties": {
        "activate-framework.defaultTier": {
          "type": "string",
          "default": "standard",
          "enum": [
            "minimal",
            "standard",
            "advanced"
          ],
          "enumDescriptions": [
            "Core workflow guidance (AGENTS.md, instructions, prompts)",
            "Core + ad-hoc instructions, skills, and agents",
            "Standard + advanced tooling"
          ],
          "description": "Default installation tier for Peregrine Activate."
        },
        "activate-framework.source": {
          "type": "string",
          "default": "bundled",
          "enum": [
            "bundled",
            "remote"
          ],
          "enumDescriptions": [
            "Use files bundled with the extension (offline, stable)",
            "Fetch files from GitHub (always latest, requires network)"
          ],
          "description": "Where Peregrine Activate loads manifest and files from."
        },
        "activate-framework.remoteRepo": {
          "type": "string",
          "default": "peregrine-digital/activate-framework",
          "description": "GitHub repository (owner/repo) for Peregrine Activate when source is 'remote'."
        },
        "activate-framework.remoteBranch": {
          "type": "string",
          "default": "main",
          "description": "Git branch or tag for Peregrine Activate when source is 'remote'."
        },
        "activate-framework.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Peregrine Activate's daily logging of GitHub Copilot premium-interaction quota usage to ~/.activate/copilot-telemetry.jsonl."
        },
        "activate-framework.telemetry.logDirectory": {
          "type": "string",
          "default": "",
          "description": "Directory for Peregrine Activate's Copilot telemetry log. Empty uses ~/.activate/. Supports ~ for home directory."
        }
      }
    }
  },
  "scripts": {
    "prepare-assets": "node scripts/prepare-assets.mjs",
    "package": "npm run prepare-assets && vsce package --no-dependencies --allow-missing-repository --skip-license",
    "test": "node --test src/__tests__/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0"
  }
}
